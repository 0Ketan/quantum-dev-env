# ==============================================================================
# quantum-dev-env .gitignore
# ==============================================================================

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl

# ─── Virtual Environments ────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ─── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── IDE / Editor ────────────────────────────────────────────────────────────
# VS Code workspace settings are committed as a template in configs/
# but ignore any local .vscode directories
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ─── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Node (if using any JS tooling) ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Testing / Coverage ─────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# ─── Build Artifacts ────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig

# ─── Generated Images from Examples ─────────────────────────────────────────
bell_state_results.png
superposition_results.png
